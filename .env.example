# Supabase project settings (Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 航班查詢（AviationStack）。留空 = 只可以手動輸入航班資料。
VITE_AVIATIONSTACK_KEY=

# TomTom Search API + Routing API 嘅 key（Places 搜尋、步行/自駕路線）。留空 = 呢啲功能停用。
VITE_TOMTOM_KEY=

# HERE Public Transit API 嘅 key（電車/公共交通路線）。留空 = 電車時間估算停用。
VITE_HERE_API_KEY=

# Taggun 收據 OCR key。留空 = 影單 OCR 停用，手信改用純手動輸入。
VITE_TAGGUN_API_KEY=
